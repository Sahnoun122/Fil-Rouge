# 🔐 Configuration JWT
JWT_SECRET=your-super-secret-jwt-key-at-least-256-bits-long
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-token-key-at-least-256-bits-long
JWT_REFRESH_EXPIRES_IN=7d

# 🗄️ Configuration Base de Données
MONGODB_URI=mongodb://localhost:27017/marketplan-ia

# 🚀 Configuration Serveur
NODE_ENV=development
PORT=3000
API_VERSION=v1

# 📧 Configuration Email (Optionnel)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=noreply@yourapp.com
FROM_NAME=MarketPlan IA

# 🔒 Configuration Sécurité
BCRYPT_ROUNDS=12
CORS_ORIGIN=http://localhost:3001
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100
FREE_MAX_SWOT=3
FREE_MAX_PDF_EXPORTS=3

# Plan Pro
PRO_MAX_STRATEGIES=25
PRO_MAX_PUBLICATIONS=100
PRO_MAX_SWOT=25
PRO_MAX_PDF_EXPORTS=25

# Plan Business (illimité = -1)
BUSINESS_MAX_STRATEGIES=-1
BUSINESS_MAX_PUBLICATIONS=-1
BUSINESS_MAX_SWOT=-1
BUSINESS_MAX_PDF_EXPORTS=-1

FRONTEND_URL=http://localhost:3001
RESET_PASSWORD_URL=http://localhost:3001/reset-password

# 🤖 Configuration OpenRouter AI (REQUIS — le backend ne démarrera pas sans ces valeurs)
OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_API_KEY=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
OPENROUTER_MODEL=nvidia/nemotron-3-nano-30b-a3b:free

LOG_LEVEL=info
LOG_FORMAT=combined